rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // A user can only read/write objects under their own path.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
