rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function canReadChild(childId) {
      return signedIn()
        && exists(/databases/$(database)/documents/children/$(childId))
        && isFamilyMember(get(/databases/$(database)/documents/children/$(childId)).data.familyId);
    }

    // A user owns everything under their own document, including children and
    // all per-child subcollections (behaviorLogs, milestones, actionPlans,
    // savedStories, contacts, weeklyReports, insights, settings, …).
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /families/{familyId} {
      allow read, update: if isFamilyMember(familyId);
      allow create: if signedIn();
      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow write: if signedIn() && request.auth.uid == memberId;
      }
    }

    match /children/{childId} {
      allow read, update: if canReadChild(childId);
      allow create: if signedIn();

      match /{subcollection}/{docId} {
        allow read, write: if canReadChild(childId);
      }
    }

    match /aiRuns/{runId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /safetyReviews/{reviewId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /organizations/{organizationId}/{document=**} {
      allow read, write: if false;
    }
  }
}
