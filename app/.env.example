# Arbor environment: local, dev, stage, prod.
ARBOR_ENV="local"
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# MODEL_PROVIDER: local development may use gemini_dev; production must use vertex.
MODEL_PROVIDER="gemini_dev"

# GEMINI_API_KEY: local development fallback only. Production Arbor uses Vertex AI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Google Cloud / Vertex AI.
GCP_PROJECT_ID="my-gcp-project"
GCP_REGION="europe-west4"
VERTEX_LOCATION="europe-west4"
VERTEX_MODEL_CHAT="claude-3-5-sonnet@anthropic"
VERTEX_MODEL_STORY="gemini-2.5-flash"
VERTEX_MODEL_ANALYSIS="gemini-2.5-flash"
VERTEX_MODEL_HANDOFF="gemini-2.5-flash"

# Firebase / Firestore (server / Admin SDK — never expose with a VITE_ prefix).
FIREBASE_PROJECT_ID="my-firebase-project"
FIRESTORE_DATABASE_ID="(default)"
MEMORY_ADAPTER="local"
ENABLE_LOCAL_MEMORY_ADAPTER="true"
ENABLE_HIGH_RISK_REVIEW_QUEUE="true"

# Require a verified Firebase ID token on /api routes. Leave false for local sandbox.
REQUIRE_AUTH="false"
# Per-user hourly cap on AI-generating endpoints (cost guardrail).
AI_USER_HOURLY_LIMIT="80"

# ── Monetization (MON-1) ────────────────────────────────────────────────────
# Turn the Free/Plus paywall ON. Production defaults ON even if unset; keep false
# only for a deliberate local/private-beta sandbox where everyone resolves to Plus.
ENFORCE_ENTITLEMENTS="false"
# Free-tier coach messages per day (only when enforcement is on).
FREE_COACH_MESSAGES_PER_DAY="10"
# Comp Plus without billing: comma-separated uids / emails (founders, testers).
ARBOR_PLUS_UIDS=""
ARBOR_PLUS_EMAILS=""

# ── Safety (AI-2) ───────────────────────────────────────────────────────────
# Adds an LLM output-safety classifier on coach responses (the lexical
# diagnosis/medication screen is always on regardless of this flag).
ENABLE_OUTPUT_SAFETY_CLASSIFIER="false"

# ── Care Network (MON-3) ────────────────────────────────────────────────────
# Where "Request consultation" intro emails go (concierge inbox). When empty,
# requests are still recorded server-side but no email draft is offered.
CONSULT_INTAKE_EMAIL=""
# Firebase Admin service-account credentials (optional; falls back to ADC on GCP).
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firebase client SDK (exposed to the browser by Vite). When unset, the app runs in
# open sandbox mode with a synthetic local user instead of gating behind login.
VITE_HAS_GEMINI_API="false"
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_APP_ID=""

# Optional. Defaults to ../knowledge from the app working directory.
ARBOR_KNOWLEDGE_PATH="../knowledge"
