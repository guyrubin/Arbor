# Arbor environment: local, dev, stage, prod.
ARBOR_ENV="local"
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# MODEL_PROVIDER: local development may use gemini_dev; production must use vertex.
MODEL_PROVIDER="gemini_dev"

# GEMINI_API_KEY: local development fallback only. Production Arbor uses Vertex AI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Google Cloud / Vertex AI.
GCP_PROJECT_ID="my-gcp-project"
GCP_REGION="europe-west4"
VERTEX_LOCATION="europe-west4"
VERTEX_MODEL_CHAT="gemini-2.5-pro"
VERTEX_MODEL_STORY="gemini-2.5-flash"
VERTEX_MODEL_ANALYSIS="gemini-2.5-flash"
VERTEX_MODEL_HANDOFF="gemini-2.5-flash"

# Firebase / Firestore.
FIREBASE_PROJECT_ID="my-firebase-project"
FIRESTORE_DATABASE_ID="(default)"
MEMORY_ADAPTER="local"
ENABLE_LOCAL_MEMORY_ADAPTER="true"
ENABLE_HIGH_RISK_REVIEW_QUEUE="true"
