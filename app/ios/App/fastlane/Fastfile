# Arbor iOS — App Store / TestFlight delivery (Fastlane).
#
# With ONLY an App Store Connect API key (ASC_KEY_ID / ASC_ISSUER_ID /
# ASC_KEY_CONTENT) Fastlane creates the distribution certificate + app-store
# provisioning profile, builds a SIGNED .ipa, and uploads it to TestFlight —
# no Mac, no manual cert export. Run from CI (.github/workflows/ios.yml) or
# locally with `bundle exec fastlane beta`.
default_platform(:ios)

platform :ios do
  desc "Build a signed app-store IPA and upload to TestFlight"
  lane :beta do
    setup_ci # creates an ephemeral keychain on CI runners

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )

    app_identifier = ENV.fetch("IOS_BUNDLE_ID", "app.arbor.family")

    # Create/download signing assets straight from the API key.
    cert(api_key: api_key)
    sigh(api_key: api_key, app_identifier: app_identifier, force: true)

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      api_key: api_key,
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build",
      output_name: "Arbor.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build a signed IPA and upload the binary + App Store listing metadata (no auto-submit)"
  lane :release do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )
    app_identifier = ENV.fetch("IOS_BUNDLE_ID", "app.arbor.family")

    cert(api_key: api_key)
    sigh(api_key: api_key, app_identifier: app_identifier, force: true)

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      api_key: api_key,
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build",
      output_name: "Arbor.ipa"
    )

    # Pushes the binary + the text metadata under fastlane/metadata/en-US.
    # Screenshots are NOT uploaded here (add them, then run with skip_screenshots:false),
    # and the build is NOT auto-submitted for review — you submit from App Store Connect.
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: "build/Arbor.ipa",
      skip_screenshots: true,
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end
end
